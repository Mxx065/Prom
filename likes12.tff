%%%%%
% Element types
%%%%%

tff( type_of_a, type, a: humans).

tff( type_of_g, type, g: humans).

tff( type_of_d, type, d: humans).

tff( type_of_c, type, c: humans).

tff( type_of_f, type, f: humans).

tff( type_of_b, type, b: humans).

tff( type_of_e, type, e: humans).


%%%%%
% Relations
%%%%%

