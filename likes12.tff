%%%%%
% Conjectures
%%%%%

tff( everybody_is_a_person, conjecture, 
	( ! [ X: humans ] : ( person(X ) ) )
).

tff( every_female_is_a_person, conjecture, 
	( ! [ X: humans ] : ( ( female(X ) => person(X ) ) ) )
).

tff( every_person_is_a_human, conjecture, 
	( ! [ X ] : ( ( person(X ) => ( X IS IN humans ) ) ) )
).

